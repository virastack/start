{
  "name": "virastack",
  "version": "1.0.0",
  "private": true,
  "description": "Premium Next.js 16 + React 19 + Tailwind CSS 4 boilerplate focused on clean architecture, UI/UX, and agent-ready developer experience.",
  "author": {
    "name": "Ömer Gülçiçek (ViraStack)",
    "email": "iletisim@omergulcicek.com",
    "url": "https://omergulcicek.com"
  },
  "license": "MIT",
  "virastack": {
    "template": "nextjs",
    "version": "1.0.0",
    "url": "https://virastack.com"
  },
  "homepage": "https://virastack.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/virastack/nextjs-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/virastack/nextjs-boilerplate/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "clean": "rimraf .next",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache && prettier --write .",
    "lint:ci": "eslint . --max-warnings=0 && prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "virastack",
    "nextjs-boilerplate",
    "nextjs-starter",
    "react-boilerplate",
    "react",
    "nextjs",
    "cursor-rules",
    "clean-architecture",
    "typescript",
    "tanstack-query",
    "tailwindcss",
    "base-ui",
    "dx"
  ],
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@next/bundle-analyzer": "^16.2.11",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-query-devtools": "^5.101.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.11",
    "next-themes": "^0.4.6",
    "nuqs": "^2.9.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.82.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@virastack/ai": "^1.2.0",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "husky": "^9.1.7",
    "knip": "^6.28.0",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
