{
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "plugins": ["@ianvs/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
  "tailwindFunctions": ["cn", "clsx", "cva"],
  "tailwindStylesheet": "./src/styles/tailwind.css",
  "importOrder": [
    "^react$",
    "^next($|/)",
    "",
    "^@tanstack/.*",
    "^zustand($|/)",
    "^lucide-react($|/)",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/types($|/)",
    "^@/constants($|/)",
    "^@/schemas($|/)",
    "^@/config($|/)",
    "^@/env($|/)",
    "",
    "^@/assets($|/)",
    "^@/styles($|/)",
    "^@/lib($|/)",
    "^@/helpers($|/)",
    "",
    "^@/providers($|/)",
    "^@/stores($|/)",
    "^@/hooks($|/)",
    "^@/data($|/)",
    "",
    "^@/components($|/)",
    "^@/layout($|/)",
    "^@/features($|/)",
    "^@/ui($|/)",
    "^@/.*",
    "",
    "^[./]"
  ],
  "importOrderParserPlugins": ["typescript", "jsx"]
}
